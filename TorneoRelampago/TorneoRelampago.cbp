<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<CodeBlocks_project_file>
	<FileVersion major="1" minor="6" />
	<Project>
		<Option title="TorneoRelampago" />
		<Option pch_mode="2" />
		<Option compiler="gcc" />
		<Option virtualFolders="Menus/;IngresoDatos/;Varios/" />
		<Build>
			<Target title="Debug">
				<Option output="bin/Debug/TorneoRelampago" prefix_auto="1" extension_auto="1" />
				<Option object_output="obj/Debug/" />
				<Option type="1" />
				<Option compiler="gcc" />
				<Compiler>
					<Add option="-g" />
				</Compiler>
			</Target>
			<Target title="Release">
				<Option output="bin/Release/TorneoRelampago" prefix_auto="1" extension_auto="1" />
				<Option object_output="obj/Release/" />
				<Option type="1" />
				<Option compiler="gcc" />
				<Compiler>
					<Add option="-O2" />
				</Compiler>
				<Linker>
					<Add option="-s" />
				</Linker>
			</Target>
		</Build>
		<Compiler>
			<Add option="-Wall" />
			<Add option="-fexceptions" />
		</Compiler>
		<Unit filename="ingresoDatos.cpp">
			<Option virtualFolder="IngresoDatos/" />
		</Unit>
		<Unit filename="ingresoDatos.h">
			<Option virtualFolder="IngresoDatos/" />
		</Unit>
		<Unit filename="main.cpp" />
		<Unit filename="menus.cpp">
			<Option virtualFolder="Menus/" />
		</Unit>
		<Unit filename="menus.h">
			<Option virtualFolder="Menus/" />
		</Unit>
		<Unit filename="varios.cpp">
			<Option virtualFolder="Varios/" />
		</Unit>
		<Unit filename="varios.h">
			<Option virtualFolder="Varios/" />
		</Unit>
		<Extensions>
			<lib_finder disable_auto="1" />
		</Extensions>
	</Project>
</CodeBlocks_project_file>
